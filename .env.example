# =============================================================================
# Verbjective — Environment Variables
# Copy this file to `.env.local` and fill in real values. NEVER commit secrets.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser; all others
# are server-only.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Your project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anonymous key (safe to expose; constrained by Row Level Security).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — FULL ADMIN, BYPASSES RLS. Server-only. Never expose.
# Used for invoice generation, storage uploads and trusted server tasks.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Google OAuth (configured in Supabase Auth providers / config.toml)
# -----------------------------------------------------------------------------
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
# API key from https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender address, e.g. "Verbjective <hello@verbjective.com>"
EMAIL_FROM=
# Address that booking/contact notifications are sent to (the tutor).
TUTOR_NOTIFICATION_EMAIL=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Canonical site URL, used for building links in emails and OAuth redirects.
NEXT_PUBLIC_SITE_URL=https://super-esl-stars.vercel.app/
